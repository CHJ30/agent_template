# ─── Dependencies ─────────────────────────────────────────────────────────────
**/node_modules/

# Yarn Berry (PnP / zero-installs) — used by clients/chat-web
**/.pnp
**/.pnp.*
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/versions

# ─── Build output ─────────────────────────────────────────────────────────────
**/dist/
**/build/
**/out/

# Next.js
**/.next/
**/next-env.d.ts

# ─── Turborepo ────────────────────────────────────────────────────────────────
**/.turbo/

# ─── Tests & coverage ─────────────────────────────────────────────────────────
**/coverage/
**/.nyc_output/
artifacts/
**/.venv/
**/.pytest_cache/
**/__pycache__/

# ─── Environment variables ────────────────────────────────────────────────────
# Remove the "!" line below if you use .env.example files and want to commit them
**/.env
**/.env.*
!**/.env.example

# ─── TypeScript ───────────────────────────────────────────────────────────────
**/*.tsbuildinfo

# ─── Logs ─────────────────────────────────────────────────────────────────────
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Runtime ──────────────────────────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ─── Secrets & certificates ───────────────────────────────────────────────────
*.pem

# ─── Temp ─────────────────────────────────────────────────────────────────────
**/.temp/
**/.tmp/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ─── Deployment ───────────────────────────────────────────────────────────────
.vercel
