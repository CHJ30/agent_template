{
	"name": "@autix/chat",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "nest start --watch",
		"build": "rm -rf dist tsconfig.tsbuildinfo && nest build",
		"start": "bun run dist/main.js",
		"typecheck": "tsc --noEmit",
		"lint": "tsc --noEmit",
