		"@langchain/openai": "^1.4.7",
		"@langchain/textsplitters": "^1.0.1",
		"@nestjs/common": "^11.0.0",
		"@nestjs/core": "^11.0.0",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/platform-express": "^11.0.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@xenova/transformers": "^2.17.2",
		"js-yaml": "^4.2.0",
		"langchain": "^1.4.4",
		"mammoth": "^1.12.0",
		"multer": "^2.2.0",
		"pdf-parse": "1.1.1",
		"pg": "^8.21.0",
