# LLM provider
OPENAI_API_KEY=replace-with-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding / vector services (leave blank when using only local embeddings + pgvector)
EMBEDDING_API_KEY=
VECTOR_DB_URL=
VECTOR_DB_API_KEY=

# PostgreSQL shared by chat persistence, pgvector and LangGraph checkpoints
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chatdb

# Runtime cost policy
MONTHLY_LLM_BUDGET_USD=100

# Application
JWT_SECRET=replace-with-a-long-random-secret
PORT=8081
LOG_LEVEL=debug

# Local multilingual embedding model download
HF_ENDPOINT=https://huggingface.co
NO_PROXY=localhost,127.0.0.1
